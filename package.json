{
  "name": "spec-mind",
  "version": "0.1.1",
  "description": "Convert OpenAPI and AsyncAPI specs to compact, LLM-friendly format",
  "author": "Marcos Segovia",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/msegoviadev/spec-mind.git"
  },
  "bugs": "https://github.com/msegoviadev/spec-mind/issues",
  "homepage": "https://github.com/msegoviadev/spec-mind#readme",
  "bin": {
    "spec-mind": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "FORMAT_SPEC.md"
  ],
  "main": "./dist/converter.js",
  "types": "./dist/converter.d.ts",
  "type": "module",
  "scripts": {
    "build": "bun build ./src/cli.ts --outdir ./dist --target bun",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^25.5.0",
    "openapi-types": "^12.1.3"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@apidevtools/swagger-parser": "^12.1.0",
    "commander": "^14.0.3"
  }
}
